rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ──────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // ─── Users ─────────────────────────────────────────────────────
    // Users can read any profile (needed for driver/rider info).
    // Users can only create/update their own profile.
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false; // Profiles should never be deleted client-side

      // ─── Preferences sub-collection ──────────────────────────────
      // Only the owning user can read/write their own preferences.
      // Documents are "notification" and "ride".
      match /preferences/{prefId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId);
        allow delete: if false;
      }

      // ─── Search History sub-collection ───────────────────────────
      // Only the owning user can manage their search history.
      match /searchHistory/{historyId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId);
        allow delete: if isOwner(userId); // Users can clear their own history
        allow update: if false; // History entries are immutable, replaced by delete+create
      }
    }

    // ─── Rides ─────────────────────────────────────────────────────
    // Any authenticated user can read rides (needed for search/matching).
    // Only the driver who owns the ride can create it.
    // Updates are allowed by the driver (status changes, seat management)
    // or by riders involved in the ride (booking a seat adds riderUid).
    match /rides/{rideId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
                    && request.resource.data.driverUid == request.auth.uid;
      allow update: if isAuthenticated()
                    && (
                      // Driver can update their own ride
                      resource.data.driverUid == request.auth.uid
                      // Riders already in the ride can update (e.g. seat booking via transaction)
                      || (resource.data.keys().hasAny(['riderUids'])
                          && request.auth.uid in resource.data.riderUids)
                      // A new rider booking themselves in — they must appear in the new riderUids
                      || (request.resource.data.keys().hasAny(['riderUids'])
                          && request.auth.uid in request.resource.data.riderUids)
                    );
      allow delete: if false; // Rides are cancelled via status change, not deletion

      // ─── Messages sub-collection (chat within a ride) ───────────
      match /messages/{messageId} {
        allow read: if isAuthenticated()
                    && (
                      get(/databases/$(database)/documents/rides/$(rideId)).data.driverUid == request.auth.uid
                      || request.auth.uid in get(/databases/$(database)/documents/rides/$(rideId)).data.riderUids
                    );
        allow create: if isAuthenticated()
                      && request.resource.data.senderId == request.auth.uid
                      && (
                        get(/databases/$(database)/documents/rides/$(rideId)).data.driverUid == request.auth.uid
                        || request.auth.uid in get(/databases/$(database)/documents/rides/$(rideId)).data.riderUids
                      );
        allow update, delete: if false; // Messages are immutable
      }
    }

    // ─── Ride Requests ─────────────────────────────────────────────
    // Riders can create requests. Both the rider and the driver of the
    // target ride can read/update the request (accept/decline/cancel).
    match /ride_requests/{requestId} {
      allow read: if isAuthenticated()
                  && (
                    resource.data.riderUid == request.auth.uid
                    || resource.data.driverUid == request.auth.uid
                  );
      allow create: if isAuthenticated()
                    && request.resource.data.riderUid == request.auth.uid;
      allow update: if isAuthenticated()
                    && (
                      resource.data.riderUid == request.auth.uid
                      || resource.data.driverUid == request.auth.uid
                    );
      allow delete: if false;
    }

    // ─── Locations ─────────────────────────────────────────────────
    // Real-time driver location tracking. Any authenticated user can read
    // (needed for rider-side tracking). Only the ride's driver can write.
    match /locations/{rideId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated()
                   && get(/databases/$(database)/documents/rides/$(rideId)).data.driverUid == request.auth.uid;
    }

    // ─── Deny everything else ──────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
